{
  "_meta": {
    "managed": true,
    "managed_by": "m2614_compliance",
    "m_26_14": {
      "element": 1,
      "workstream": 3,
      "description": "Asset configuration baseline snapshots for drift detection. Each document is a point-in-time baseline of a canonical asset (from m_26_14-assets): identity, OS version, and a configuration hash. The Asset Drift dashboard compares current state against these snapshots; the WS3 drift-detection watcher (planned) writes m_26_14.drift_detected onto the canonical record when current state diverges from the latest baseline."
    }
  },
  "index_patterns": ["m_26_14-asset-baselines"],
  "priority": 500,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "index.number_of_replicas": 1,
      "index.codec": "best_compression"
    },
    "mappings": {
      "dynamic": false,
      "properties": {
        "@timestamp": { "type": "date" },
        "asset": {
          "properties": {
            "id":   { "type": "keyword" },
            "name": { "type": "keyword" },
            "last_seen": { "type": "date" },
            "os": {
              "properties": {
                "name":     { "type": "keyword" },
                "version":  { "type": "keyword" },
                "build":    { "type": "keyword" },
                "platform": { "type": "keyword" }
              }
            },
            "hardware": {
              "properties": {
                "serial_number": { "type": "keyword" }
              }
            },
            "compliance": {
              "properties": {
                "encrypted":     { "type": "boolean" },
                "mdm_enrolled":  { "type": "boolean" },
                "mdm_compliant": { "type": "boolean" }
              }
            }
          }
        },
        "m_26_14": {
          "properties": {
            "baseline_hash":      { "type": "keyword" },
            "baseline_timestamp": { "type": "date" }
          }
        }
      }
    }
  }
}
