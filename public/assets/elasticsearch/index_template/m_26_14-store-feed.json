{
  "index_patterns": [
    "m_26_14-store-feed*"
  ],
  "priority": 200,
  "_meta": {
    "pack": "m_26_14",
    "purpose": "Entity Store v2 discovery feed (decisions #18/#21). Written by the m_26_14-store-feed transform; add this index pattern to the Security default data view so the store mints entities for devices it cannot discover from raw documents (syslog-named, observers, hostname-less). Maps host.name as keyword (NOT dynamic text). Dest pipeline promotes data_stream.dataset and event.module attestation onto feed docs so entity.source on discovered hosts shows which log streams referenced them. Discovered entities carry no asset.id. Do NOT add the full m_26_14-observed ledger to the data view."
  },
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "last_log": {
          "type": "date"
        },
        "first_log": {
          "type": "date"
        },
        "event_count": {
          "type": "long"
        },
        "dataset_count": {
          "type": "long"
        },
        "datasets": {
          "type": "flattened"
        },
        "event_modules": {
          "type": "flattened"
        },
        "appnames": {
          "type": "keyword"
        },
        "data_stream": {
          "properties": {
            "dataset": {
              "type": "keyword"
            }
          }
        },
        "event": {
          "properties": {
            "module": {
              "type": "keyword"
            }
          }
        },
        "m_26_14": {
          "properties": {
            "collector": {
              "type": "keyword"
            },
            "attestation": {
              "type": "keyword"
            }
          }
        },
        "host": {
          "properties": {
            "name": {
              "type": "keyword"
            }
          }
        }
      }
    }
  }
}
