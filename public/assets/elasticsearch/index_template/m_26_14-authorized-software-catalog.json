{
  "_meta": {
    "managed": true,
    "managed_by": "m_26_14",
    "m_26_14": {
      "workstream": 3,
      "description": "Authorized software catalog (SWAM allowlist) — enrich source index for the m_26_14-authorized-software enrich policy used by the m_26_14-osquery-normalize pipeline. One doc per package name; carries authorization state, category, publisher, EOL flag, and CDM approval provenance (approved_by / approval_ref / min_version)."
    }
  },
  "index_patterns": ["m_26_14-authorized-software-catalog"],
  "priority": 500,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "index.number_of_replicas": 1,
      "index.auto_expand_replicas": "0-1"
    },
    "mappings": {
      "dynamic": false,
      "properties": {
        "package": {
          "properties": {
            "name": { "type": "keyword" }
          }
        },
        "authorized":   { "type": "boolean" },
        "category":     { "type": "keyword" },
        "publisher":    { "type": "keyword" },
        "eol":          { "type": "boolean" },
        "approved_by":  { "type": "keyword" },
        "approval_ref": { "type": "keyword" },
        "min_version":  { "type": "keyword" },
        "updated_at":   { "type": "date" }
      }
    }
  }
}
