{
  "_meta": {
    "managed": true,
    "managed_by": "m_26_14",
    "m_26_14": {
      "workstream": 3,
      "description": "Network interface inventory data stream for M-26-14 network visibility"
    }
  },
  "index_patterns": [
    "logs-m_26_14_osquery.network_inventory-*"
  ],
  "data_stream": {},
  "priority": 300,
  "template": {
    "settings": {
      "index.mode": "logsdb",
      "index.default_pipeline": "m_26_14-osquery-normalize",
      "index.lifecycle.name": "m_26_14-asset-inventory"
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "agent": {
          "properties": {
            "id": {
              "type": "keyword"
            },
            "name": {
              "type": "keyword"
            },
            "hostname": {
              "type": "keyword"
            },
            "version": {
              "type": "keyword"
            },
            "type": {
              "type": "keyword"
            }
          }
        },
        "host": {
          "properties": {
            "id": {
              "type": "keyword"
            },
            "name": {
              "type": "keyword"
            },
            "type": {
              "type": "keyword"
            },
            "ip": {
              "type": "ip"
            },
            "mac": {
              "type": "keyword"
            }
          }
        },
        "network": {
          "properties": {
            "interface": {
              "type": "keyword"
            },
            "type": {
              "type": "keyword"
            },
            "mtu": {
              "type": "integer"
            }
          }
        },
        "osquery": {
          "properties": {
            "name": {
              "type": "keyword"
            },
            "action": {
              "type": "keyword"
            }
          }
        },
        "m_26_14": {
          "properties": {
            "managed": {
              "type": "boolean"
            },
            "hwam_source": {
              "type": "keyword"
            },
            "asset_fingerprint": {
              "type": "keyword"
            }
          }
        },
        "asset": {
          "properties": {
            "id": {
              "type": "keyword"
            },
            "name": {
              "type": "keyword"
            },
            "source": {
              "type": "keyword"
            },
            "managed": {
              "type": "boolean"
            },
            "last_seen": {
              "type": "date"
            },
            "network": {
              "type": "nested",
              "properties": {
                "interface": {
                  "type": "keyword"
                },
                "ip": {
                  "type": "ip"
                },
                "mac": {
                  "type": "keyword"
                },
                "type": {
                  "type": "keyword"
                }
              }
            }
          }
        }
      },
      "date_detection": false
    }
  }
}
