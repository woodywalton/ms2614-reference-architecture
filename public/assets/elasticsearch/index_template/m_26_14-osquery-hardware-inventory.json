{
  "_meta": {
    "managed": true,
    "managed_by": "m2614_compliance",
    "m_26_14": {
      "workstream": 3,
      "description": "Hardware inventory data stream for M-26-14 Element 1 (HWAM)"
    }
  },
  "index_patterns": ["logs-m_26_14_osquery.hardware_inventory-*"],
  "data_stream": {},
  "priority": 300,
  "template": {
    "settings": {
      "index.mode": "logsdb",
      "index.default_pipeline": "m_26_14-osquery-normalize",
      "index.lifecycle.name": "m_26_14-asset-inventory"
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": { "type": "date" },
        "agent": {
          "properties": {
            "id":       { "type": "keyword" },
            "name":     { "type": "keyword" },
            "hostname": { "type": "keyword" },
            "version":  { "type": "keyword" },
            "type":     { "type": "keyword" }
          }
        },
        "host": {
          "properties": {
            "id":       { "type": "keyword" },
            "name":     { "type": "keyword" },
            "hostname": { "type": "keyword" },
            "os": {
              "properties": {
                "name":     { "type": "keyword" },
                "version":  { "type": "keyword" },
                "family":   { "type": "keyword" },
                "platform": { "type": "keyword" },
                "build":    { "type": "keyword" },
                "eol":      { "type": "boolean" }
              }
            }
          }
        },
        "osquery": {
          "properties": {
            "name":   { "type": "keyword" },
            "action": { "type": "keyword" }
          }
        },
        "m_26_14": {
          "properties": {
            "managed":           { "type": "boolean" },
            "hwam_source":       { "type": "keyword" },
            "asset_type":        { "type": "keyword" },
            "asset_fingerprint": { "type": "keyword" },
            "hardware": {
              "properties": {
                "model":             { "type": "keyword" },
                "vendor":            { "type": "keyword" },
                "serial":            { "type": "keyword" },
                "cpu_brand":         { "type": "keyword" },
                "cpu_cores_physical":{ "type": "integer" },
                "cpu_cores_logical": { "type": "integer" },
                "memory_bytes":      { "type": "long" },
                "board_vendor":      { "type": "keyword" },
                "board_model":       { "type": "keyword" }
              }
            }
          }
        },
        "asset": {
          "properties": {
            "id":          { "type": "keyword" },
            "name":        { "type": "keyword" },
            "fqdn":        { "type": "keyword" },
            "type":        { "type": "keyword" },
            "criticality": { "type": "keyword" },
            "status":      { "type": "keyword" },
            "managed":     { "type": "boolean" },
            "first_seen":  { "type": "date" },
            "last_seen":   { "type": "date" },
            "source":      { "type": "keyword" },
            "source_id":   { "type": "keyword" },
            "hardware": {
              "properties": {
                "manufacturer":     { "type": "keyword" },
                "model":            { "type": "keyword" },
                "serial_number":    { "type": "keyword" },
                "bios_uuid":        { "type": "keyword" },
                "bios_version":     { "type": "keyword" },
                "bios_manufacturer":{ "type": "keyword" },
                "cpu": {
                  "properties": {
                    "brand":          { "type": "keyword" },
                    "cores_physical": { "type": "integer" },
                    "cores_logical":  { "type": "integer" }
                  }
                },
                "memory_bytes": { "type": "long" },
                "chassis_type": { "type": "keyword" }
              }
            },
            "os": {
              "properties": {
                "name":         { "type": "keyword" },
                "version":      { "type": "keyword" },
                "build":        { "type": "keyword" },
                "platform":     { "type": "keyword" },
                "architecture": { "type": "keyword" },
                "eol":          { "type": "boolean" },
                "patch_level":  { "type": "keyword" }
              }
            },
            "compliance": {
              "properties": {
                "encrypted":      { "type": "boolean" },
                "mdm_enrolled":   { "type": "boolean" },
                "mdm_compliant":  { "type": "boolean" },
                "patch_compliant":{ "type": "boolean" },
                "last_check":     { "type": "date" }
              }
            },
            "organization": {
              "properties": {
                "owner":      { "type": "keyword" },
                "department": { "type": "keyword" },
                "location":   { "type": "keyword" },
                "asset_tag":  { "type": "keyword" },
                "tags":       { "type": "keyword" }
              }
            }
          }
        }
      }
    }
  }
}
