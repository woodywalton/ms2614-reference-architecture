{
  "_meta": {
    "managed": true,
    "managed_by": "m2614_compliance",
    "m_26_14": {
      "element": 5,
      "level": 4,
      "description": "JIT (just-in-time) access grant register for Element 5 Level 4. Each grant is one document; the grant itself is implemented as an Elasticsearch role mapping named m_26_14-jit-{grant_id} so revocation is a single idempotent DELETE _security/role_mapping call. The m_26_14-jit-expiry watcher revokes expired grants every 15 minutes; the m_26_14-jit-audit watcher reports daily on grants active >72h."
    }
  },
  "index_patterns": ["m_26_14-jit-grants"],
  "priority": 500,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "index.number_of_replicas": 1,
      "index.codec": "best_compression"
    },
    "mappings": {
      "dynamic": false,
      "properties": {
        "@timestamp":        { "type": "date" },
        "grant_id":          { "type": "keyword" },
        "username":          { "type": "keyword" },
        "role":              { "type": "keyword" },
        "role_mapping_name": { "type": "keyword" },
        "case_id":           { "type": "keyword" },
        "granted_by":        { "type": "keyword" },
        "granted_at":        { "type": "date" },
        "expires_at":        { "type": "date" },
        "status":            { "type": "keyword" },
        "revoked_at":        { "type": "date" },
        "revoked_by":        { "type": "keyword" },
        "justification":     { "type": "text" }
      }
    }
  }
}
