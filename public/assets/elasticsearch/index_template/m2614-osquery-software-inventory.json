{
  "_meta": {
    "managed": true,
    "managed_by": "m2614_compliance",
    "m2614": {
      "workstream": 3,
      "description": "Software inventory data stream for M-26-14 Element 2 (SWAM)"
    }
  },
  "index_patterns": ["logs-m2614_osquery.software_inventory-*"],
  "data_stream": {},
  "priority": 300,
  "template": {
    "settings": {
      "index.mode": "logsdb",
      "index.default_pipeline": "m2614-osquery-normalize",
      "index.lifecycle.name": "m2614-asset-inventory"
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": { "type": "date" },
        "agent": {
          "properties": {
            "id":       { "type": "keyword" },
            "name":     { "type": "keyword" },
            "hostname": { "type": "keyword" },
            "version":  { "type": "keyword" },
            "type":     { "type": "keyword" }
          }
        },
        "host": {
          "properties": {
            "id":   { "type": "keyword" },
            "name": { "type": "keyword" }
          }
        },
        "package": {
          "properties": {
            "name":         { "type": "keyword" },
            "version":      { "type": "keyword" },
            "type":         { "type": "keyword" },
            "architecture": { "type": "keyword" },
            "install_path": { "type": "keyword" },
            "publisher":    { "type": "keyword" },
            "category":     { "type": "keyword" }
          }
        },
        "osquery": {
          "properties": {
            "name":   { "type": "keyword" },
            "action": { "type": "keyword" }
          }
        },
        "m2614": {
          "properties": {
            "managed":           { "type": "boolean" },
            "hwam_source":       { "type": "keyword" },
            "asset_fingerprint": { "type": "keyword" },
            "software": {
              "properties": {
                "authorized": { "type": "boolean" },
                "category":   { "type": "keyword" },
                "publisher":  { "type": "keyword" },
                "eol":        { "type": "boolean" }
              }
            }
          }
        },
        "asset": {
          "properties": {
            "id":       { "type": "keyword" },
            "name":     { "type": "keyword" },
            "source":   { "type": "keyword" },
            "managed":  { "type": "boolean" },
            "last_seen":{ "type": "date" }
          }
        }
      }
    }
  }
}
