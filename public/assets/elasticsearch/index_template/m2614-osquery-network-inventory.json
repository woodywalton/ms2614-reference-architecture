{
  "_meta": {
    "managed": true,
    "managed_by": "m2614_compliance",
    "m2614": {
      "workstream": 3,
      "description": "Network interface inventory data stream for M-26-14 network visibility"
    }
  },
  "index_patterns": ["logs-m2614_osquery.network_inventory-*"],
  "data_stream": {},
  "priority": 300,
  "template": {
    "settings": {
      "index.mode": "logsdb",
      "index.default_pipeline": "m2614-osquery-normalize",
      "index.lifecycle.name": "m2614-asset-inventory"
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": { "type": "date" },
        "agent": {
          "properties": {
            "id":       { "type": "keyword" },
            "name":     { "type": "keyword" },
            "hostname": { "type": "keyword" },
            "version":  { "type": "keyword" },
            "type":     { "type": "keyword" }
          }
        },
        "host": {
          "properties": {
            "id":  { "type": "keyword" },
            "name":{ "type": "keyword" },
            "ip":  { "type": "ip" },
            "mac": { "type": "keyword" }
          }
        },
        "network": {
          "properties": {
            "interface": { "type": "keyword" },
            "type":      { "type": "keyword" },
            "mtu":       { "type": "integer" }
          }
        },
        "osquery": {
          "properties": {
            "name":   { "type": "keyword" },
            "action": { "type": "keyword" }
          }
        },
        "m2614": {
          "properties": {
            "managed":           { "type": "boolean" },
            "hwam_source":       { "type": "keyword" },
            "asset_fingerprint": { "type": "keyword" }
          }
        },
        "asset": {
          "properties": {
            "id":      { "type": "keyword" },
            "name":    { "type": "keyword" },
            "source":  { "type": "keyword" },
            "managed": { "type": "boolean" },
            "network": {
              "type": "nested",
              "properties": {
                "interface": { "type": "keyword" },
                "ip":        { "type": "ip" },
                "mac":       { "type": "keyword" },
                "type":      { "type": "keyword" }
              }
            }
          }
        }
      }
    }
  }
}
