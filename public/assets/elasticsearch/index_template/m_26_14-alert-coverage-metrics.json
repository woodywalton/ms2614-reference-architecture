{
  "_meta": {
    "managed": true,
    "managed_by": "m_26_14",
    "m_26_14": {
      "workstream": 6,
      "description": "Index template for M-26-14 alert coverage metrics produced by the daily and latest transforms"
    }
  },
  "index_patterns": ["m_26_14-metrics-alert-coverage-*"],
  "priority": 300,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "index.number_of_replicas": 1,
      "index.lifecycle.name": "m_26_14-asset-inventory"
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "day_bucket": {
          "type": "date"
        },
        "appendix_b_category": {
          "type": "keyword"
        },
        "category_letter": {
          "type": "keyword"
        },
        "alert_count": {
          "type": "long"
        },
        "last_alert_ts": {
          "type": "date"
        },
        "kibana": {
          "properties": {
            "alert": {
              "properties": {
                "rule": {
                  "properties": {
                    "rule_id": {
                      "type": "keyword"
                    },
                    "name": {
                      "type": "keyword"
                    },
                    "tags": {
                      "type": "keyword"
                    }
                  }
                },
                "severity": {
                  "type": "keyword"
                }
              }
            }
          }
        }
      }
    }
  }
}
