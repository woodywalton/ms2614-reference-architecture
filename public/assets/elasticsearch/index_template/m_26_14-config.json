{
  "index_patterns": ["m_26_14-config"],
  "priority": 200,
  "_meta": {
    "pack": "m_26_14",
    "purpose": "Single-document configuration index: the only place a threshold lives. Holds the LRA publication date (drives deadline countdowns), Appendix C per-element/per-level thresholds (editable when CISA's LRA publishes), retention day targets, scoring cadence, and operator attestations for properties Elasticsearch cannot observe (encryption at rest on ECE/self-managed, GRC two-gate retirement). Seed document ships in M3."
  },
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1
    },
    "mappings": {
      "dynamic": false,
      "runtime": {
        "config_key": {
          "type": "keyword",
          "script": { "source": "emit('default')" }
        }
      },
      "properties": {
        "lra": {
          "properties": {
            "published": { "type": "date" }
          }
        },
        "thresholds": {
          "properties": {
            "inventory":  { "properties": { "l1": {"type":"integer"}, "l2": {"type":"integer"}, "l3": {"type":"integer"}, "l4": {"type":"integer"} } },
            "coverage":   { "properties": { "l1": {"type":"integer"}, "l2": {"type":"integer"}, "l3": {"type":"integer"}, "l4": {"type":"integer"} } },
            "operations": { "properties": { "l1": {"type":"integer"}, "l2": {"type":"integer"}, "l3": {"type":"integer"}, "l4": {"type":"integer"} } },
            "retention": {
              "properties": {
                "l1_retrievable_days": {"type":"integer"},
                "l2_retrievable_days": {"type":"integer"},
                "l3_searchable_days":  {"type":"integer"},
                "l3_retrievable_days": {"type":"integer"},
                "l4_searchable_days":  {"type":"integer"},
                "l4_retrievable_days": {"type":"integer"}
              }
            }
          }
        },
        "attestations": {
          "properties": {
            "encryption_at_rest":       { "type": "boolean" },
            "encryption_at_rest_note":  { "type": "text" },
            "two_gate_retirement":      { "type": "boolean" },
            "two_gate_retirement_note": { "type": "text" }
          }
        },
        "scoring": {
          "properties": {
            "cadence": { "type": "keyword" }
          }
        }
      }
    }
  }
}
