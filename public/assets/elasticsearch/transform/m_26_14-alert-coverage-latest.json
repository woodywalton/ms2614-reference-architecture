{
  "source": {
    "index": [".alerts-security.*", ".alerts-security.test"],
    "query": {
      "term": {
        "kibana.alert.rule.tags": "M-26-14"
      }
    }
  },
  "latest": {
    "unique_key": ["kibana.alert.rule.rule_id"],
    "sort": "@timestamp"
  },
  "dest": {
    "index": "m_26_14-metrics-alert-coverage-latest"
  },
  "frequency": "1h",
  "sync": {
    "time": {
      "field": "@timestamp",
      "delay": "60s"
    }
  },
  "description": "M-26-14 Appendix B alert coverage — latest alert per rule for compliance status",
  "_meta": {
    "managed": true,
    "managed_by": "m_26_14",
    "m_26_14": {
      "workstream": 6,
      "description": "Latest transform: current compliance status — one document per rule_id showing most recent alert"
    }
  }
}
