{
  "datafeed_id": "datafeed-auth_rare_source_ip_for_a_user",
  "job_id": "auth_rare_source_ip_for_a_user",
  "indices": [
    "logs-system.auth-*",
    "logs-windows.security-*",
    "logs-azure.signinlogs-*",
    "logs-okta.system-*",
    "logs-elasticsearch.audit-*"
  ],
  "query": {
    "bool": {
      "must": [
        {"exists": {"field": "user.name"}},
        {"exists": {"field": "source.ip"}}
      ]
    }
  },
  "scroll_size": 1000,
  "chunking_config": {"mode": "auto"}
}
