{
  "datafeed_id": "datafeed-auth_high_count_logon_fails_for_a_user",
  "job_id": "auth_high_count_logon_fails_for_a_user",
  "indices": [
    "logs-system.auth-*",
    "logs-windows.security-*",
    "logs-azure.signinlogs-*",
    "logs-okta.system-*",
    "logs-elasticsearch.audit-*"
  ],
  "query": {
    "bool": {
      "must": [{"exists": {"field": "user.name"}}]
    }
  },
  "scroll_size": 1000,
  "chunking_config": {"mode": "auto"}
}
