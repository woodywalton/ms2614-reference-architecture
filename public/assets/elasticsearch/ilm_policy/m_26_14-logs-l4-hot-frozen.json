{
  "_meta": {
    "managed": true,
    "managed_by": "m_26_14",
    "m_26_14": {
      "element": 4,
      "level": 4,
      "searchable_months": 6,
      "retrievable_months": 12
    }
  },
  "description": "M-26-14 Appendix C Element 4 Level 4 — Hot/Frozen retention. Hot tier (0-180d) = searchable (immediately usable for cyber defense). Frozen tier via Searchable Snapshots (180-365d) = retrievable. Total 12-month retention satisfies L4.",
  "policy": {
    "phases": {
      "hot": {
        "min_age": "0ms",
        "actions": {
          "rollover": {
            "max_age": "1d",
            "max_primary_shard_size": "50gb"
          },
          "set_priority": {
            "priority": 100
          }
        }
      },
      "frozen": {
        "min_age": "180d",
        "actions": {
          "searchable_snapshot": {
            "snapshot_repository": "found-snapshots",
            "force_merge_index": true
          }
        }
      },
      "delete": {
        "min_age": "365d",
        "actions": {
          "wait_for_snapshot": {
            "policy": "m_26_14-compliance-snapshots"
          },
          "delete": {}
        }
      }
    }
  }
}
