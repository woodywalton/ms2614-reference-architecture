{
  "_meta": {
    "managed": true,
    "managed_by": "m2614_compliance",
    "m2614": {
      "element": 1,
      "description": "HWAM/SWAM asset inventory records — long retention, low ingest volume"
    }
  },
  "description": "M-26-14 asset inventory retention — 3 year audit trail for HWAM/SWAM records. Hot (7d active), Frozen via Searchable Snapshots (long-term compliance archive).",
  "policy": {
    "phases": {
      "hot": {
        "min_age": "0ms",
        "actions": {
          "rollover": {
            "max_age": "7d",
            "max_primary_shard_size": "10gb"
          },
          "set_priority": {
            "priority": 100
          }
        }
      },
      "frozen": {
        "min_age": "30d",
        "actions": {
          "searchable_snapshot": {
            "snapshot_repository": "m2614-compliance-snapshots",
            "force_merge_index": true
          },
          "set_priority": {
            "priority": 0
          }
        }
      },
      "delete": {
        "min_age": "1095d",
        "actions": {
          "delete": {}
        }
      }
    }
  }
}
