{
  "_meta": {
    "managed": true,
    "managed_by": "m2614_compliance"
  },
  "description": "M-26-14 Appendix C Element 5 Level 3 — log integrity hashing. Computes SHA-256 fingerprint of canonical ECS event fields at ingest time. Deploy as final_pipeline on logs-* index templates.",
  "version": 1,
  "processors": [
    {
      "fingerprint": {
        "description": "SHA-256 hash of canonical ECS event fields for tamper detection",
        "fields": [
          "@timestamp",
          "event.category",
          "event.action",
          "event.outcome",
          "event.type",
          "source.ip",
          "source.port",
          "destination.ip",
          "destination.port",
          "user.name",
          "user.id",
          "host.name",
          "host.id",
          "process.name",
          "process.pid",
          "process.executable",
          "file.path",
          "network.protocol",
          "message"
        ],
        "target_field": "event.hash",
        "method": "SHA-256",
        "ignore_missing": true
      }
    },
    {
      "set": {
        "description": "Record ingest timestamp for chain-of-custody",
        "field": "event.integrity.ingested_at",
        "value": "{{{_ingest.timestamp}}}"
      }
    },
    {
      "set": {
        "description": "Version tag enables future algorithm migration",
        "field": "event.integrity.algorithm",
        "value": "SHA-256-v1"
      }
    },
    {
      "set": {
        "field": "event.integrity.hashed",
        "value": true
      }
    }
  ],
  "on_failure": [
    {
      "set": {
        "field": "event.integrity.hashed",
        "value": false
      }
    },
    {
      "set": {
        "field": "event.integrity.failure_reason",
        "value": "{{{_ingest.on_failure_message}}}"
      }
    },
    {
      "append": {
        "field": "tags",
        "value": "m_26_14-hash-failure"
      }
    }
  ]
}
